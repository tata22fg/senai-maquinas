# ─── Configuração de Banco de Dados ────────────────────────────────────────
# URL de conexão MySQL/TiDB
# Formato: mysql://usuario:senha@host:porta/banco_de_dados
DATABASE_URL=mysql://root:password@localhost:3306/senai_machines

# ─── Configuração de Autenticação OAuth ────────────────────────────────────
# ID da aplicação no portal OAuth
VITE_APP_ID=seu_app_id_aqui

# URL do servidor OAuth
OAUTH_SERVER_URL=https://oauth.manus.im

# Chave secreta para assinar tokens JWT de sessão
# Gere uma chave segura: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_aqui

# OpenID do proprietário (será promovido a admin)
OWNER_OPEN_ID=seu_open_id_aqui

# ─── Configuração de Porta ────────────────────────────────────────────────
# Porta em que o servidor rodará (padrão: 3000)
PORT=3000

# ─── Configuração de Ambiente ────────────────────────────────────────────
# development, production
NODE_ENV=development

# ─── Configuração de E-mail ────────────────────────────────────────────────────
# Configuração SMTP (opcional - se não configurado, usará Ethereal para testes)
# Host do servidor SMTP
SMTP_HOST=smtp.gmail.com

# Porta do servidor SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Usuário para autenticação SMTP
SMTP_USER=seu-email@gmail.com

# Senha ou App Password para autenticação SMTP
SMTP_PASS=sua-app-password

# Usar conexão segura (true para porta 465, false para outras portas)
SMTP_SECURE=false

# Endereço de e-mail do remetente
EMAIL_FROM=noreply@senai-machines.local
